# === Voice Server Config ===
WS_PORT=8765
IPC_PORT=8766
IPC_SECRET=change-me-to-a-secure-random-string
MAX_CONCURRENT_CALLS=20

# === VapiClone Connection ===
VAPICLONE_API_URL=https://vapiclone-production.up.railway.app
VAPICLONE_API_KEY=your-vapiclone-api-key

# === Ollama (LLM) ===
OLLAMA_URL=http://ollama:11434/v1
OLLAMA_MODEL=llama3.1:8b

# === Whisper (STT) ===
WHISPER_MODEL=base.en

# === TTS Services ===
KOKORO_API_URL=http://localhost:8880
# QWEN3_API_URL=http://localhost:8881
PIPER_MODELS_DIR=/models/piper
PIPER_VOICE=en_US-lessac-medium

# === Optional: Paid providers (leave blank to use free alternatives) ===
# OPENAI_API_KEY=
# DEEPGRAM_API_KEY=
# ELEVENLABS_API_KEY=
# DEEPSEEK_API_KEY=

# === Twilio (for call transfer TwiML) ===
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
