# === Voice Server Config ===
WS_PORT=8765
IPC_PORT=8766
IPC_SECRET=change-me-to-a-secure-random-string
NODE_ENV=production
ENV_FILE_PATH=/opt/voiceserverV2/.env

# === Default LLM ===
# This model is pre-warmed on startup. Use -4k variants for phone calls (4K context).
# Create with: echo "FROM model:tag\nPARAMETER num_ctx 4096" | ollama create model:tag-4k
DEFAULT_LLM=qwen2.5:3b-4k

# === VapiClone Connection ===
VAPICLONE_API_URL=https://vapiclone-production.up.railway.app
VAPICLONE_API_KEY=your-vapiclone-api-key

# === Ollama (LLM) ===
OLLAMA_URL=http://localhost:11434/v1
OLLAMA_FLASH_ATTENTION=1
OLLAMA_NUM_PARALLEL=18
OLLAMA_KEEP_ALIVE=-1
# OLLAMA_NUM_CTX is NOT a server env var — use Modelfiles with PARAMETER num_ctx 4096 instead

# === Overflow LLM (auto-routes to cloud when Ollama slots full) ===
OVERFLOW_LLM_PROVIDER=groq
OVERFLOW_LLM_MODEL=llama-3.1-8b-instant

# === STT ===
# Production STT is Deepgram Flux (paid). Vosk is free fallback.
# DEEPGRAM_API_KEY=your-deepgram-key

# === TTS Services ===
KOKORO_MODELS_DIR=/models/kokoro
KOKORO_VOICE=af_heart
CLONED_VOICES_DIR=/data/cloned-voices
CHATTERBOX_VOICES_DIR=/data/chatterbox-voices
# QWEN3_API_URL=http://localhost:8881

# === Groq (overflow LLM, TTS, STT) ===
# GROQ_API_KEY=
# GROQ_TTS_API_KEY=
# GROQ_STT_API_KEY=

# === Other LLM Providers (for overflow) ===
# CEREBRAS_API_KEY=
# DEEPSEEK_API_KEY=
# DEEPINFRA_API_KEY=

# === Telephony ===
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# SW_PROJECT_ID=
# SW_SPACE_URL=
# SW_AUTH_TOKEN=

# === Misc ===
HF_HOME=/root/.cache/huggingface
CONDA_PATH=/root/miniconda3/bin/conda
# UNREALSPEECH_API_KEY=
